# Example environment variables for EduAI project

# Key for the third‑party educational chatbot service.  Can also be named
# HUGGINGFACE_API_KEY if you're using Hugging Face.
# EDU_CHATBOT_KEY="your_chatbot_api_key_here"
# or
# HUGGINGFACE_API_KEY="hf_fKASPPYLkasgjasKwpSnAASRdasdCdAsddsASSDF"
EDU_CHATBOT_KEY= your_chatbot_api_key_here

# Secret key for NextAuth.js.  This should be a long, random string in production.  You can generate one using a tool like `openssl rand -base64 32`.   
NEXTAUTH_SECRET="your_nextauth_secret_here"
DATABASE_URL="your_database_connection_string_here"
NEXTAUTH_URL="http://localhost:3000"
