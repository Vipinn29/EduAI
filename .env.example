# Example environment variables for EduAI project

# OpenRouter API Key for accessing OpenAI models
# Get your key from: https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"

# Secret key for NextAuth.js.  This should be a long, random string in production.  You can generate one using a tool like `openssl rand -base64 32`.   
NEXTAUTH_SECRET="your_nextauth_secret_here"
DATABASE_URL="your_database_connection_string_here"
NEXTAUTH_URL="http://localhost:3000"
